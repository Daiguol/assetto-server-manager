{
  "name": "server-manager",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "build": "npm run build:js && npm run build:css && npm run copy:fonts",
    "build:js": "vite build",
    "build:css": "sass sass/server-manager.scss:../static/css/server-manager.css sass/server-manager-dark.scss:../static/css/server-manager-dark.css --load-path=node_modules --style=compressed --source-map --quiet-deps",
    "copy:fonts": "node -e \"require('fs').cpSync('node_modules/summernote/dist/font','../static/css/font',{recursive:true})\"",
    "watch": "vite build --watch"
  },
  "author": "",
  "license": "ISC",
