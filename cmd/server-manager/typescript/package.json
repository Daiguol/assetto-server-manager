    "@fortawesome/free-solid-svg-icons": "^5.12.0",
    "@fullcalendar/bootstrap": "^4.3.0",
    "@fullcalendar/core": "^4.3.1",
    "@fullcalendar/list": "^4.3.0",
    "@fullcalendar/timegrid": "^4.3.0",
    "@ttskch/select2-bootstrap4-theme": "^1.4.0",
